# GoldPath — environment variables

# Operator portal token (gates /ops + /api/admin/*)
ADMIN_TOKEN=

# Postgres (Neon Postgres recommended via Vercel Marketplace)
# Phase 1 falls back to JSONL file storage if unset.
DATABASE_URL=

# Resend transactional email (waitlist confirmation, signup)
RESEND_API_KEY=

# Default theme (GP = locked GoldPath brand)
# Six legacy directions still selectable via ?theme=A1|A2|B1|B2|C1|C2 for QA.
NEXT_PUBLIC_DEFAULT_THEME=GP

# Show the 6-way theme switcher in the UI (dev only). 0 hides, 1 shows.
NEXT_PUBLIC_THEME_SWITCHER=0

# Founders count baseline — added to the real signup count for display.
# Default 0 = honest count. Set to a positive integer to seed visible
# traction during a staged launch. Hard-capped at FOUNDERS_CAP (5000).
FOUNDERS_BASELINE=0
