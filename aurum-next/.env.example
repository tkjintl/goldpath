# Aurum — Phase 1 waitlist
# Copy to .env.local and fill in.

# Resend (transactional email — confirms waitlist signup)
RESEND_API_KEY=

# Postgres (Neon recommended via Vercel Marketplace)
# Phase 1 falls back to JSONL file storage if unset.
DATABASE_URL=

# Internal admin token for /api/waitlist GET (operator console preview)
ADMIN_TOKEN=
